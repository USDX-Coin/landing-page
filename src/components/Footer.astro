---
import { navLinks } from "../data/navigation";
import { socials } from "../data/socials";
import { socialIconPaths } from "../data/icons";
---
<footer class="bg-dark text-white py-16 px-6">
  <div class="max-w-[1200px] mx-auto">
    <div class="grid md:grid-cols-3 gap-12 mb-12">
      <!-- Logo & Tagline -->
      <div>
        <div class="flex items-center gap-2 mb-4">
          <img src="/image/Logo.svg" alt="USDX" class="w-8 h-8" />
          <span class="font-bold text-xl text-primary">USDX</span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed">
          The transparent and regulated USD stablecoin. Fully backed by US
          Dollar cash reserves and US Treasury bonds.
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h4 class="font-semibold mb-4 text-sm uppercase tracking-widest text-gray-400">Quick Links</h4>
        <div class="flex flex-col gap-3">
          {navLinks.map((link) => (
            <a href={link.href} class="text-gray-300 hover:text-primary text-sm no-underline transition-colors">
              {link.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Social -->
      <div>
        <h4 class="font-semibold mb-4 text-sm uppercase tracking-widest text-gray-400">Community</h4>
        <div class="flex gap-3">
          {socials.map((social) => (
            <a
              href={social.url}
              target="_blank"
              rel="noopener noreferrer"
              class="w-10 h-10 rounded-lg bg-white/10 hover:bg-primary/20 flex items-center justify-center transition-colors no-underline"
              aria-label={social.name}
            >
              <svg class="w-5 h-5 fill-gray-300" viewBox="0 0 24 24">
                <path d={socialIconPaths[social.icon]} />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <!-- Brand tagline -->
    <div class="mb-12">
      <h3 class="text-xl sm:text-2xl md:text-3xl font-bold text-white leading-tight">
        The Future of<br />
        <span class="text-primary">Digital Dollars</span>
      </h3>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-white/10 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-gray-500 text-sm">&copy; 2026 USDX. All rights reserved.</p>
      <a href="#" class="text-gray-500 hover:text-gray-300 text-sm no-underline transition-colors">
        Terms &amp; Conditions
      </a>
    </div>
  </div>
</footer>
