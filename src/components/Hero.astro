---
const headingText = "The Transparent & Regulated ";
const highlightText = "USD Stablecoin";
---
<section class="pt-40 pb-20 px-6 bg-white relative overflow-hidden">
  <!-- Dot grid pattern -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle, #1eaed5 1px, transparent 1px); background-size: 24px 24px;"></div>
  <!-- Gradient glow -->
  <div class="absolute top-20 right-0 w-[500px] h-[500px] bg-primary/5 rounded-full blur-3xl"></div>

  <div class="max-w-[1200px] mx-auto flex flex-col md:flex-row items-center gap-12 relative z-10">
    <!-- Text -->
    <div class="flex-1 text-center md:text-left animate-on-scroll">
      <h1 id="hero-heading" class="text-3xl md:text-5xl lg:text-[52px] font-bold leading-tight tracking-tight">
        {headingText.split("").map((char) => (
          <span data-char class="text-dark" style="opacity: 0; transition: opacity 0.01s;">{char === " " ? "\u00A0" : char}</span>
        ))}
        {highlightText.split("").map((char) => (
          <span data-char class="text-primary" style="opacity: 0; transition: opacity 0.01s;">{char === " " ? "\u00A0" : char}</span>
        ))}
        <span id="hero-cursor" class="text-primary" style="animation: cursor-blink 1s infinite;">|</span>
      </h1>
      <p class="mt-6 text-gray-600 text-lg leading-relaxed max-w-xl" style="opacity: 0; transition: opacity 0.5s ease-out 1.8s;" id="hero-desc">
        USDX is a fully-backed digital dollar, redeemable 1:1 for USD.
        Secured by US Treasury bonds and cash reserves, audited by
        independent third-party firms.
      </p>
      <div class="mt-8 flex flex-col sm:flex-row items-center gap-4 md:justify-start justify-center" style="opacity: 0; transition: opacity 0.5s ease-out 2s;" id="hero-ctas">
        <a
          href="https://app-usdx.netlify.app/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center px-8 py-3 bg-primary text-white font-semibold rounded-lg hover:bg-primary-dark transition-colors no-underline text-base"
        >
          Get USDX
        </a>
        <a
          href="#why-usdx"
          class="inline-flex items-center text-primary font-semibold hover:text-primary-dark transition-colors no-underline text-base"
        >
          Learn More
          <svg class="ml-2 w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
          </svg>
        </a>
      </div>
    </div>

    <!-- SVG 3D Coin -->
    <div class="flex-shrink-0 animate-on-scroll" style="transition-delay: 300ms;">
      <div class="animate-float">
        <svg viewBox="0 0 200 200" class="w-64 h-64 md:w-80 md:h-80">
          <defs>
            <linearGradient id="ring" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#1eaed5" stop-opacity="0.3" />
              <stop offset="100%" stop-color="#1899bc" stop-opacity="0.1" />
            </linearGradient>
            <radialGradient id="coinFace" cx="40%" cy="35%">
              <stop offset="0%" stop-color="#22c5e8" />
              <stop offset="50%" stop-color="#1eaed5" />
              <stop offset="100%" stop-color="#1580a0" />
            </radialGradient>
            <linearGradient id="coinEdge" x1="0" y1="0" x2="0" y2="1">
              <stop offset="0%" stop-color="#1899bc" />
              <stop offset="100%" stop-color="#0e6b82" />
            </linearGradient>
            <radialGradient id="highlight" cx="35%" cy="30%">
              <stop offset="0%" stop-color="white" stop-opacity="0.4" />
              <stop offset="100%" stop-color="white" stop-opacity="0" />
            </radialGradient>
          </defs>
          <circle cx="100" cy="100" r="95" fill="none" stroke="url(#ring)" stroke-width="2" />
          <circle cx="100" cy="100" r="85" fill="none" stroke="url(#ring)" stroke-width="1" />
          <ellipse cx="100" cy="108" rx="72" ry="72" fill="url(#coinEdge)" />
          <circle cx="100" cy="100" r="72" fill="url(#coinFace)" />
          <circle cx="100" cy="100" r="72" fill="url(#highlight)" />
          <circle cx="100" cy="100" r="60" fill="none" stroke="white" stroke-width="1" opacity="0.2" />
          <text x="100" y="112" text-anchor="middle" font-family="Inter, sans-serif" font-weight="700" font-size="52" fill="white">$</text>
          <text x="100" y="132" text-anchor="middle" font-family="Inter, sans-serif" font-weight="600" font-size="11" fill="white" opacity="0.8">USDX</text>
          <ellipse cx="100" cy="185" rx="50" ry="8" fill="black" opacity="0.08" />
        </svg>
      </div>
    </div>
  </div>
</section>

<script>
  const heading = document.getElementById('hero-heading');
  const desc = document.getElementById('hero-desc');
  const ctas = document.getElementById('hero-ctas');
  const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  if (heading && !reducedMotion) {
    const spans = heading.querySelectorAll<HTMLSpanElement>('span[data-char]');
    spans.forEach((span, i) => {
      setTimeout(() => { span.style.opacity = '1'; }, i * 30 + 500);
    });
    const cursor = document.getElementById('hero-cursor');
    if (cursor) {
      setTimeout(() => { cursor.style.display = 'none'; }, spans.length * 30 + 2500);
    }
    // Show description and CTAs after typewriter
    if (desc) setTimeout(() => { desc.style.opacity = '1'; }, spans.length * 30 + 800);
    if (ctas) setTimeout(() => { ctas.style.opacity = '1'; }, spans.length * 30 + 1000);
  } else {
    // Reduced motion: show everything immediately
    heading?.querySelectorAll<HTMLSpanElement>('span[data-char]').forEach(s => { s.style.opacity = '1'; });
    if (desc) desc.style.opacity = '1';
    if (ctas) ctas.style.opacity = '1';
    const cursor = document.getElementById('hero-cursor');
    if (cursor) cursor.style.display = 'none';
  }
</script>
