---
import { features } from "../data/features";

const iconPaths: Record<string, string> = {
  shield: "M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z",
  zap: "M13 10V3L4 14h7v7l9-11h-7z",
  dollar: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1",
  layers: "M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z",
  check: "M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4",
  globe: "M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z",
};
---
<section id="features" class="py-24 px-6 bg-white">
  <div class="max-w-[1200px] mx-auto animate-on-scroll">
    <div class="flex items-center gap-3 mb-6">
      <span class="w-2.5 h-2.5 rounded-full bg-primary"></span>
      <span class="text-primary font-semibold text-sm uppercase tracking-widest">Features</span>
    </div>
    <div class="h-px bg-gray-200 mb-8"></div>
    <h2 class="text-3xl md:text-4xl font-bold text-dark text-center mb-16">Key Features</h2>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {features.map((feature, index) => (
        <div
          class="p-8 rounded-xl border border-gray-100 hover:-translate-y-1 hover:shadow-lg transition-all duration-300 animate-on-scroll"
          style={`transition-delay: ${index * 100}ms;`}
        >
          <div class="w-12 h-12 rounded-lg bg-primary-light flex items-center justify-center mb-5">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={iconPaths[feature.icon]} />
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-dark mb-3">
            <span class="text-primary">{feature.title.split(" ")[0]}</span>{" "}
            {feature.title.split(" ").slice(1).join(" ")}
          </h3>
          <p class="text-gray-600 leading-relaxed text-sm">{feature.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>
